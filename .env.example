# Salin ke .env di root proyek: cp .env.example .env

# ── MySQL (Docker Compose service: database) ──
DB_PASSWORD=your_mysql_root_password
DB_USER=root
DB_NAME=db_rag_web

# ── Backend Express ──
PORT=5000
JWT_SECRET=ubah-ini-jadi-random-panjang
JWT_EXPIRES_IN=7d
GUEST_USER_EMAIL=guest@rag.local
FRONTEND_ORIGIN=http://localhost,http://localhost:5173,https://cine-chat-rag.vercel.app

# Backend di host (npm run dev) → pakai port publish Docker
# DB_HOST=127.0.0.1
# DB_PORT=3307

# Backend di Docker Compose → di-override otomatis ke database:3306

# ── Node-RED ──
# API key dibaca Node-RED via env.get() / header valueType:env (bukan $(VAR) di URL)
# Jika Pinecone "Unauthorized" padahal key sudah di-set → key invalid/expired atau index URL salah
GEMINI_API_KEY=
PINECONE_API_KEY=
NODE_RED_CREDENTIAL_SECRET=

# Koneksi MySQL Sakila untuk Node-RED (di Docker: hostname = database)
MYSQL_HOST=database
MYSQL_PORT=3306
MYSQL_DATABASE_SAKILA=sakila

# Railway MySQL: set MYSQL_HOST/MYSQL_PORT dari variable service MySQL Railway
# contoh: MYSQL_HOST=${{MYSQL.MYSQLHOST}}  MYSQL_PORT=${{MYSQL.MYSQLPORT}}

# Backend → Node-RED (di host)
NODE_RED_BASE_URL=http://localhost:1880
NODE_RED_URL=/api/chat
NODE_RED_TIMEOUT_MS=120000

# ── Frontend build (Docker) ──
VITE_API_BASE_URL=http://localhost:5000/api
