NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rag_web_chat
DB_CONNECTION_LIMIT=10

# User tamu untuk chat sebelum login terhubung
GUEST_USER_EMAIL=guest@rag.local

# Auth JWT
JWT_SECRET=ubah-ini-jadi-random-panjang
JWT_EXPIRES_IN=7d

# Optional: dipakai jika NODE_RED_*_URL diisi path relatif (contoh: /webhook/rag)
NODE_RED_BASE_URL=http://localhost:1880

# Isi URL endpoint HTTP request Node-RED kamu
NODE_RED_RAG_URL=
NODE_RED_OLTP_URL=
NODE_RED_DWH_URL=

# Timeout request ke Node-RED (ms)
NODE_RED_TIMEOUT_MS=30000
