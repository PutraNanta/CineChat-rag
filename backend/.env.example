NODE_ENV=development
PORT=5000
# Pisahkan beberapa origin dengan koma.
FRONTEND_ORIGIN=http://localhost:5173,http://localhost,https://cine-chat-rag.vercel.app

# MySQL — jalankan backend DI HOST (npm run dev), MySQL via Docker publish
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=db_rag_web
DB_CONNECTION_LIMIT=10

# Jika backend jalan di Docker Compose, DB_HOST/DB_PORT di-override ke database:3306

# User tamu untuk chat sebelum login terhubung
GUEST_USER_EMAIL=guest@rag.local

# Auth JWT
JWT_SECRET=ubah-ini-jadi-random-panjang
JWT_EXPIRES_IN=7d

# Optional: dipakai jika NODE_RED_URL diisi path relatif (contoh: /webhook/chat)
NODE_RED_BASE_URL=http://localhost:1880

# Isi URL endpoint HTTP request Node-RED kamu
NODE_RED_URL=

# Timeout request ke Node-RED (ms)
NODE_RED_TIMEOUT_MS=30000

# Node-RED / Gemini / Pinecone — set di root .env untuk Docker Compose
# (GEMINI_API_KEY & PINECONE_API_KEY dipakai service nodered)
